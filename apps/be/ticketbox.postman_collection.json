{
  "info": {
    "_postman_id": "75b17bdb-f1c5-4d8c-bc2d-9fbff4d69a01",
    "name": "TicketBox Backend",
    "description": "Postman collection for the NestJS backend endpoints currently registered in src/app.module.ts: Health and Auth. Default baseUrl is http://localhost:3001. Run the backend before testing. Use Register first to generate a test account, then Login, Profile, Refresh, and Logout.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "GET /health",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status code is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "const json = pm.response.json();",
                  "",
                  "pm.test('response is wrapped by interceptor', function () {",
                  "  pm.expect(json).to.have.property('statusCode', 200);",
                  "  pm.expect(json).to.have.property('data');",
                  "});",
                  "",
                  "pm.test('health status is ok', function () {",
                  "  pm.expect(json.data).to.eql({ status: 'ok' });",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/health",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "health"
              ]
            },
            "description": "Checks the backend health endpoint from AppController."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Auth",
      "description": "AuthModule endpoints from src/routes/auth/auth.controller.ts. Refresh token is stored as an httpOnly cookie named refreshToken on /auth/refresh.",
      "item": [
        {
          "name": "POST /auth/register - Register test account",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const timestamp = Date.now();",
                  "pm.collectionVariables.set('testEmail', `ticketbox.user.${timestamp}@example.com`);",
                  "pm.collectionVariables.set('testPhone', `09${String(timestamp).slice(-8)}`);",
                  "pm.collectionVariables.set('testPassword', 'password123');",
                  "pm.collectionVariables.set('testFullName', 'TicketBox Test User');"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status code is 201', function () {",
                  "  pm.response.to.have.status(201);",
                  "});",
                  "",
                  "const json = pm.response.json();",
                  "const user = json.data;",
                  "",
                  "pm.test('registered user is returned', function () {",
                  "  pm.expect(user).to.have.property('id');",
                  "  pm.expect(user.email).to.eql(pm.collectionVariables.get('testEmail'));",
                  "});",
                  "",
                  "pm.test('registered user has customer role', function () {",
                  "  pm.expect(user.roles).to.be.an('array');",
                  "  pm.expect(user.roles.map((role) => role.name)).to.include('customer');",
                  "});",
                  "",
                  "pm.collectionVariables.set('userId', user.id);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{testEmail}}\",\n  \"phone\": \"{{testPhone}}\",\n  \"password\": \"{{testPassword}}\",\n  \"fullName\": \"{{testFullName}}\",\n  \"status\": \"ACTIVE\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/register",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "register"
              ]
            },
            "description": "Creates a unique test user each time this request runs. The pre-request script updates testEmail/testPhone/testPassword/testFullName collection variables."
          },
          "response": []
        },
        {
          "name": "POST /auth/login - Login and save access token",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status code is 201', function () {",
                  "  pm.response.to.have.status(201);",
                  "});",
                  "",
                  "const json = pm.response.json();",
                  "const data = json.data || json;",
                  "const accessToken = data && data.accessToken;",
                  "",
                  "pm.test('login returns user and access token', function () {",
                  "  pm.expect(data).to.have.property('user');",
                  "  pm.expect(data).to.have.property('accessToken');",
                  "  pm.expect(data.user.email).to.eql(pm.collectionVariables.get('testEmail'));",
                  "});",
                  "",
                  "pm.test('login user has customer role', function () {",
                  "  pm.expect(data.user.roles).to.be.an('array');",
                  "  pm.expect(data.user.roles.map((role) => role.name)).to.include('customer');",
                  "});",
                  "",
                  "pm.collectionVariables.set('accessToken', accessToken);",
                  "if (pm.environment.name) {",
                  "  pm.environment.set('accessToken', accessToken);",
                  "}",
                  "pm.collectionVariables.set('userId', data.user.id);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{testEmail}}\",\n  \"password\": \"{{testPassword}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "login"
              ]
            },
            "description": "Logs in with the account created by Register. Saves accessToken and userId as collection variables. Postman should also keep the refreshToken cookie returned by the server."
          },
          "response": []
        },
        {
          "name": "GET /auth/profile - Current user",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const accessToken = pm.collectionVariables.get('accessToken') || pm.environment.get('accessToken') || pm.variables.get('accessToken');",
                  "",
                  "if (!accessToken) {",
                  "  throw new Error('Missing accessToken. Run POST /auth/login first.');",
                  "}",
                  "",
                  "pm.request.headers.upsert({",
                  "  key: 'Authorization',",
                  "  value: `Bearer ${accessToken}`",
                  "});"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status code is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "const user = pm.response.json().data;",
                  "",
                  "pm.test('profile matches logged in user', function () {",
                  "  pm.expect(user).to.have.property('id', pm.collectionVariables.get('userId'));",
                  "  pm.expect(user).to.have.property('email', pm.collectionVariables.get('testEmail'));",
                  "});",
                  "",
                  "pm.test('profile returns roles', function () {",
                  "  pm.expect(user.roles).to.be.an('array');",
                  "  pm.expect(user.roles.map((role) => role.name)).to.include('customer');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/auth/profile",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "profile"
              ]
            },
            "description": "Requires Authorization: Bearer {{accessToken}} from Login or Refresh."
          },
          "response": []
        },
        {
          "name": "POST /auth/refresh - Rotate tokens",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status code is 201', function () {",
                  "  pm.response.to.have.status(201);",
                  "});",
                  "",
                  "const data = pm.response.json().data;",
                  "const accessToken = data && data.accessToken;",
                  "",
                  "pm.test('refresh returns a new access token', function () {",
                  "  pm.expect(data).to.have.property('accessToken');",
                  "  pm.expect(data).to.have.property('user');",
                  "});",
                  "",
                  "pm.test('refresh user has roles', function () {",
                  "  pm.expect(data.user.roles).to.be.an('array');",
                  "  pm.expect(data.user.roles.map((role) => role.name)).to.include('customer');",
                  "});",
                  "",
                  "pm.collectionVariables.set('accessToken', accessToken);",
                  "if (pm.environment.name) {",
                  "  pm.environment.set('accessToken', accessToken);",
                  "}",
                  "pm.collectionVariables.set('userId', data.user.id);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/auth/refresh",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "refresh"
              ]
            },
            "description": "Uses the httpOnly refreshToken cookie set by Login. Run Login first in the same Postman client/session."
          },
          "response": []
        },
        {
          "name": "POST /auth/logout - Clear refresh cookie",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status code is 201', function () {",
                  "  pm.response.to.have.status(201);",
                  "});",
                  "",
                  "const data = pm.response.json().data;",
                  "",
                  "pm.test('logout message returned', function () {",
                  "  pm.expect(data).to.have.property('message', 'Logged out successfully');",
                  "});",
                  "",
                  "pm.collectionVariables.unset('accessToken');"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/auth/logout",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "logout"
              ]
            },
            "description": "Clears the refreshToken cookie and removes accessToken from collection variables."
          },
          "response": []
        },
        {
          "name": "POST /auth/login - Invalid password",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status code is 401', function () {",
                  "  pm.response.to.have.status(401);",
                  "});",
                  "",
                  "const json = pm.response.json();",
                  "",
                  "pm.test('error response shape is returned', function () {",
                  "  pm.expect(json).to.have.property('success', false);",
                  "  pm.expect(json).to.have.property('message');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{testEmail}}\",\n  \"password\": \"wrong-password\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "login"
              ]
            },
            "description": "Negative test for invalid credentials. Run Register first so testEmail exists."
          },
          "response": []
        },
        {
          "name": "GET /auth/profile - Missing token",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status code is 401', function () {",
                  "  pm.response.to.have.status(401);",
                  "});",
                  "",
                  "const json = pm.response.json();",
                  "",
                  "pm.test('unauthorized error shape is returned', function () {",
                  "  pm.expect(json).to.have.property('success', false);",
                  "  pm.expect(json.metadata).to.have.property('path', '/auth/profile');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/auth/profile",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "profile"
              ]
            },
            "description": "Negative test for protected route without Authorization header."
          },
          "response": []
        }
      ]
    }
  ],
